{
  "name": "erebus-api",
  "version": "0.0.1",
  "description": "O Erebus Api é o servidor Web API do Sistema Erebus.",
  "productName": "Erebus Api Server",
  "author": "Pedro 'Ratto' Paixão <rattopedro@gmail.com>",
  "license": "GPL-2.0-only",
  "type": "module",
  "scripts": {
    "start": "tsx src/server.ts",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "test:ui": "NODE_OPTIONS='--experimental-vm-modules' jest --ui=tdd",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "tsc",
    "db:migrate": "drizzle-kit migrate",
    "db:seed:skills": "tsx src/infrastructure/database/seeds/skills.seed.ts",
    "db:seed:weapons": "tsx src/infrastructure/database/seeds/weapons.seed.ts",
    "db:seed:enhancements": "tsx src/infrastructure/database/seeds/enhancements.seed.ts",
    "db:seed:protective-equipment": "tsx src/infrastructure/database/seeds/protective_equipment.seed.ts"
  },
  "devDependencies": {
    "@eslint/css": "^1.0.0",
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^7.5.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.5.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "inversify": "^8.1.0",
    "morgan": "^1.10.1",
    "reflect-metadata": "^0.2.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  }
}
